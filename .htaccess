# <<<|||\\\---*** This is in the root https://drjessie.life/ DrJessie.life site ***---///|||>>>
# Last updated: 2026-05-16
# Backup of previous version: .htaccess.bak-2026-03-10

# ===========================================================================
# 1. CACHE STRATEGY (DEPLOY-SAFE)
#    - HTML/service worker: never cached
#    - Versioned static assets: cache hard for 1 year
#    - Unversioned static assets: always revalidate
# ===========================================================================
<IfModule mod_setenvif.c>
  # Query-string versioning, for example: ?v=20260516, ?ver=1.2.3, ?hash=abc123
  SetEnvIfNoCase Query_String "(^|&)(v|ver|rev|version|hash)=[^&]+" ASSET_VERSIONED=1

  # Filename fingerprinting, for example: app.a1b2c3d4.css or app-20260516.js
  SetEnvIfNoCase Request_URI "[._-][0-9a-f]{8,}\.(css|js|mjs|json|jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|eot)$" ASSET_VERSIONED=1
  SetEnvIfNoCase Request_URI "[._-][0-9]{8,}\.(css|js|mjs|json|jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|eot)$" ASSET_VERSIONED=1
</IfModule>

<IfModule mod_headers.c>
  Header merge Vary "Accept-Encoding"

  # HTML and app-shell files should always be fetched fresh
  <FilesMatch "^(index\.html|service-worker\.js|sw\.js|manifest\.webmanifest)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(html|htm)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  # Versioned assets can be cached aggressively
  <FilesMatch "\.(css|js|mjs|json|jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|eot)$">
    Header always set Cache-Control "public, max-age=31536000, immutable" env=ASSET_VERSIONED
  </FilesMatch>

  # Non-versioned assets are revalidated on every request
  <FilesMatch "\.(css|js|mjs|json|jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|eot)$">
    Header always set Cache-Control "no-cache, must-revalidate, max-age=0" env=!ASSET_VERSIONED
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On

  # Keep fallback Expires values aligned with the revalidation strategy
  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 0 seconds"
  ExpiresByType application/javascript    "access plus 0 seconds"
  ExpiresByType text/javascript           "access plus 0 seconds"
  ExpiresByType application/json          "access plus 0 seconds"
  ExpiresByType application/manifest+json "access plus 0 seconds"
  ExpiresByType image/jpeg                "access plus 0 seconds"
  ExpiresByType image/png                 "access plus 0 seconds"
  ExpiresByType image/gif                 "access plus 0 seconds"
  ExpiresByType image/webp                "access plus 0 seconds"
  ExpiresByType image/svg+xml             "access plus 0 seconds"
  ExpiresByType image/x-icon              "access plus 0 seconds"
  ExpiresByType image/vnd.microsoft.icon  "access plus 0 seconds"
  ExpiresByType font/woff                 "access plus 0 seconds"
  ExpiresByType font/woff2                "access plus 0 seconds"
  ExpiresByType application/font-woff     "access plus 0 seconds"
  ExpiresByType application/font-woff2    "access plus 0 seconds"
</IfModule>


# ===========================================================================
# 1. CUSTOM ERROR PAGES
# ===========================================================================
ErrorDocument 404 /404.html
ErrorDocument 403 /404.html

# ===========================================================================
# 2. REWRITES — HTTPS + WWW CANONICALIZATION
#    All traffic → https://www.drjessie.life (matches canonical URLs)
# ===========================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Preserve Authorization header for PHP under CGI/FastCGI
  RewriteCond %{HTTP:Authorization} .+
  RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
  # Force a single canonical redirect to HTTPS + www
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} !^www\.drjessie\.life$ [NC]
  RewriteRule ^ https://www.drjessie.life%{REQUEST_URI} [L,R=301,NE]

  # Clean URL: /books → /books.html (optional, only if you want extensionless URLs later)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>

# ===========================================================================
# 3. SECURITY HEADERS
# ===========================================================================
<IfModule mod_headers.c>
  # Prevent MIME-type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Prevent clickjacking (site cannot be embedded in iframes on other domains)
  Header set X-Frame-Options "SAMEORIGIN"

  # Control referrer info sent to other sites
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy — disable features the site doesn't use
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # HSTS — tell browsers to always use HTTPS (1 year)
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

  # Prevent pages from being cached when served over HTTP (belt-and-suspenders)
  Header set X-XSS-Protection "1; mode=block"
</IfModule>


# ===========================================================================
# 5. GZIP / DEFLATE COMPRESSION
#    Reduces transfer size for text-based assets (~60-70% smaller).
# ===========================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ===========================================================================
# 6. CORRECT MIME TYPES
#    Ensures browsers interpret files correctly.
# ===========================================================================
<IfModule mod_mime.c>
  AddType image/webp                .webp
  AddType image/svg+xml             .svg .svgz
  AddType application/manifest+json .webmanifest
  AddType application/json          .json
  AddType font/woff                 .woff
  AddType font/woff2                .woff2
  AddType text/javascript           .mjs
</IfModule>

# ===========================================================================
# 7. ETAG CONFIGURATION
#    Keep validators stable and lightweight for revalidation requests.
# ===========================================================================
FileETag MTime Size

# ===========================================================================
# 8. BLOCK ACCESS TO SENSITIVE FILES
#    Prevent direct access to dotfiles, backups, and config.
# ===========================================================================

# Block all dotfiles except .well-known (used by SSL cert renewals)
<IfModule mod_rewrite.c>
  RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L]
  RewriteRule ^uploads/(contact_messages|rate_limit)(/|$) - [F,L,NC]
</IfModule>

# Block backup and config files
<FilesMatch "\.(bak|old1|config|dist|inc|ini|log|sh|sql|swp)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Block access to hidden version control directories
<IfModule mod_rewrite.c>
  RewriteRule (^|/)(?:\.git|\.svn|\.hg)(?:/|$) - [F,L]
</IfModule>

# ===========================================================================
# 9. PREVENT DIRECTORY LISTING
# ===========================================================================
Options -Indexes

# ===========================================================================
# 10. IMAGE HOTLINK PROTECTION (optional — uncomment to enable)
#     Blocks other sites from embedding your images and using your bandwidth.
# ===========================================================================
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTP_REFERER} !^$
#   RewriteCond %{HTTP_REFERER} !^https?://(www\.)?drjessie\.life/ [NC]
#   RewriteCond %{HTTP_REFERER} !^https?://(www\.)?google\. [NC]
#   RewriteCond %{HTTP_REFERER} !^https?://(www\.)?bing\. [NC]
#   RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,NC]
# </IfModule>

# ===========================================================================
# 11. PHP HANDLER (cPanel)
# ===========================================================================
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>

# <<<|||\\\---*** End - This is from the DrJessie.life site ***---///|||>>>
